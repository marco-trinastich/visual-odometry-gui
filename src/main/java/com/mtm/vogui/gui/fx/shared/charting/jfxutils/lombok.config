# Vendored third-party charting library (gillius/jfxutils, Apache-2.0). It predates the project's
# fluent-accessor convention and calls the standard getX()/setX() Lombok accessors, so restore the
# default (non-fluent, non-chained) accessor style for this subtree only. Directory-scoped: overrides
# the project root lombok.config (fluent=true) for the vendored sources, leaving our own code untouched.
lombok.accessors.fluent=false
lombok.accessors.chain=false
