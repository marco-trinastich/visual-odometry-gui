<?import atlantafx.base.controls.ToggleSwitch?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
  Input section. Only the toolbar coupling (setTimedEnabled on the Device source) is still deferred —
  it has no FX target yet. See InputSettingsViewModel.
-->
<TitledPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mtm.vogui.gui.fx.features.settings.input.InputSettingsController"
            text="Input" collapsible="true" animated="true">

    <VBox spacing="10">
        <padding>
            <Insets top="2" right="2" bottom="2" left="2"/>
        </padding>

        <!-- Calibration -->
        <GridPane hgap="10" vgap="7">
            <columnConstraints>
                <ColumnConstraints halignment="LEFT" minWidth="-Infinity"/>
                <ColumnConstraints hgrow="ALWAYS" halignment="RIGHT"/>
            </columnConstraints>
            <Label text="Calibration" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <HBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                <ComboBox fx:id="calibrationCombo" editable="true" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                <Button fx:id="calibrationBrowse" text="…"/>
            </HBox>
        </GridPane>

        <Separator/>

        <!-- Source: Video path vs Device driver -->
        <Label text="Source"/>
        <GridPane hgap="10" vgap="7">
            <columnConstraints>
                <ColumnConstraints halignment="LEFT" minWidth="-Infinity"/>
                <ColumnConstraints hgrow="ALWAYS" halignment="RIGHT"/>
            </columnConstraints>
            <RadioButton fx:id="videoRadio" text="Video" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <HBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                <ComboBox fx:id="videoCombo" editable="true" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                <MenuButton fx:id="videoBrowse" text="…">
                    <items>
                        <MenuItem fx:id="videoBrowseFile" text="Video file…"/>
                        <MenuItem fx:id="videoBrowseFolder" text="Image sequence folder…"/>
                    </items>
                </MenuButton>
            </HBox>
            <RadioButton fx:id="deviceRadio" text="Device" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="deviceTypeCombo" maxWidth="Infinity"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <!-- Device path + resolution (discovery-backed): same grid as the source rows so the combos
                 share the column (perfect left alignment); revealed only when the source is a device -->
            <Label fx:id="pathLabel" text="Path" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="devicePathCombo" editable="true" maxWidth="Infinity"
                      GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label fx:id="resolutionLabel" text="Resolution" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <ComboBox fx:id="deviceResolutionCombo" editable="true" maxWidth="Infinity"
                      GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </GridPane>

        <!-- Device adjustments (V4L4J-specific): revealed only when that driver is the chosen source -->
        <VBox fx:id="v4l4jGroup" spacing="7">
            <Label text="Adjustments (V4L4J)"/>
            <GridPane hgap="10" vgap="7">
                <columnConstraints>
                    <ColumnConstraints halignment="LEFT" minWidth="-Infinity"/>
                    <ColumnConstraints halignment="LEFT"/>
                </columnConstraints>
                <Label text="Sustain Framerate" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ToggleSwitch fx:id="sustainFramerateToggle" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Timeout Image I/O" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ToggleSwitch fx:id="timeoutImageIOToggle" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="Keep Format" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ToggleSwitch fx:id="keepFormatToggle" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>

        <Separator/>

        <!-- Preview flags -->
        <GridPane hgap="10" vgap="7">
            <columnConstraints>
                <ColumnConstraints halignment="LEFT" minWidth="-Infinity"/>
                <ColumnConstraints halignment="LEFT"/>
            </columnConstraints>
            <Label text="Full-Resolution Preview" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ToggleSwitch fx:id="fullResolutionPreviewToggle" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Input Preview (Slower)" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ToggleSwitch fx:id="inputPreviewToggle" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        </GridPane>
    </VBox>
</TitledPane>
