<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckMenuItem?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mtm.vogui.gui.fx.features.shell.ShellController"
            prefWidth="1280" prefHeight="800">

    <top>
        <VBox>
            <MenuBar>
                <Menu text="Settings">
                    <MenuItem text="Load Settings" onAction="#onLoadSettings"/>
                    <MenuItem text="Save Settings" onAction="#onSaveSettings"/>
                    <MenuItem text="Reset Settings" onAction="#onResetSettings"/>
                    <SeparatorMenuItem/>
                    <Menu text="Save Format">
                        <RadioMenuItem fx:id="formatJson" text="JSON" onAction="#onSelectJsonFormat"/>
                        <RadioMenuItem fx:id="formatYaml" text="YAML" onAction="#onSelectYamlFormat"/>
                    </Menu>
                    <CheckMenuItem fx:id="mnuAutosave" text="Autosave on Exit" onAction="#onToggleAutosave"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit" onAction="#onExit"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About" onAction="#onAbout"/>
                </Menu>
            </MenuBar>
            <ToolBar>
                <Button fx:id="startButton" text="Start"/>
                <Button fx:id="pauseButton" text="Pause"/>
                <Button fx:id="resetButton" text="Reset"/>
                <Button fx:id="stopButton" text="Stop"/>
                <Button fx:id="timedStopButton" text="Timed Stop"/>
                <Button fx:id="clearButton" text="Clear"/>
            </ToolBar>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.28">
            <StackPane fx:id="settingsPane"/>
            <SplitPane orientation="VERTICAL" dividerPositions="0.62">
                <StackPane>
                    <Label text="Charts — Fase 3"/>
                </StackPane>
                <StackPane fx:id="videoPane"/>
            </SplitPane>
        </SplitPane>
    </center>

    <bottom>
        <HBox>
            <padding>
                <Insets top="4" right="10" bottom="4" left="10"/>
            </padding>
            <Label fx:id="statusLabel"/>
        </HBox>
    </bottom>

</BorderPane>
