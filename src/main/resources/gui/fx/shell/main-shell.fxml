<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckMenuItem?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mtm.vogui.gui.fx.shell.MainShellController"
            prefWidth="1280" prefHeight="800">

    <top>
        <VBox>
            <MenuBar>
                <Menu text="Settings">
                    <MenuItem text="Load Settings" disable="true"/>
                    <MenuItem text="Save Settings" onAction="#onSaveSettings"/>
                    <MenuItem text="Reset Settings" disable="true"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Switch Format" disable="true"/>
                    <CheckMenuItem fx:id="mnuAutosave" text="Autosave on Exit" onAction="#onToggleAutosave"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit" onAction="#onExit"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About" onAction="#onAbout"/>
                </Menu>
            </MenuBar>
            <ToolBar>
                <Button text="Start" disable="true"/>
                <Button text="Pause" disable="true"/>
                <Button text="Reset" disable="true"/>
                <Button text="Stop" disable="true"/>
                <Button text="Timed Stop" disable="true"/>
                <Button text="Clear" disable="true"/>
            </ToolBar>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.28">
            <StackPane>
                <Label text="Settings — Fase 2"/>
            </StackPane>
            <SplitPane orientation="VERTICAL" dividerPositions="0.62">
                <StackPane>
                    <Label text="Charts — Fase 3"/>
                </StackPane>
                <SplitPane dividerPositions="0.5">
                    <StackPane>
                        <Label text="Video Input — Fase 2"/>
                    </StackPane>
                    <StackPane>
                        <Label text="VO Processing — Fase 2"/>
                    </StackPane>
                </SplitPane>
            </SplitPane>
        </SplitPane>
    </center>

    <bottom>
        <HBox>
            <padding>
                <Insets top="4" right="10" bottom="4" left="10"/>
            </padding>
            <Label fx:id="statusLabel"/>
        </HBox>
    </bottom>

</BorderPane>
